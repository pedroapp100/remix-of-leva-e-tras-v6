# LEVA E TRAZ — Template de variáveis de ambiente
# ═══════════════════════════════════════════════════════════════
# Copie este arquivo para .env.local e preencha os valores reais.
# Este arquivo pode ser commitado — NÃO coloque credenciais reais aqui.
# ═══════════════════════════════════════════════════════════════

VITE_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=SEU_ANON_KEY_AQUI

# Substituir com seus dados — Dashboard → Settings → Database → Database password
DATABASE_URL="postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"
